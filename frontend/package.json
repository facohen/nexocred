{
  "name": "nexocred-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "e2e": "playwright test",
    "gen:api": "node scripts/gen-api.mjs",
    "gen:api:export": "cd ../backend && conda run --no-capture-output -n nexocred python -m scripts.exportar_openapi",
    "gen:api:full": "npm run gen:api:export && npm run gen:api",
    "gen:api:check": "node scripts/gen-api.mjs && git diff --exit-code -- src/lib/api/schema.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.8",
    "@tanstack/react-query": "^5.51.0",
    "@tanstack/react-router": "^1.45.0",
    "@tanstack/react-table": "^8.19.0",
    "@tremor/react": "^3.18.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "idb": "^8.0.3",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.1.0",
    "msw": "^2.3.1",
    "openapi-typescript": "^7.0.0",
    "postcss": "^8.4.39",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.3.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.0.0"
  }
}
